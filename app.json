{
  "expo": {
    "name": "Senopati Academy",
    "slug": "senopati-academy",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "senopati",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#18c29c",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "id.senopatiacademy.app",
      "associatedDomains": ["applinks:senopatiacademy.id"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Gunakan Face ID untuk masuk ke Senopati Academy dengan cepat dan aman."
      }
    },
    "android": {
      "package": "id.senopatiacademy.app",
      "adaptiveIcon": {
        "backgroundColor": "#18c29c",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "senopatiacademy.id", "pathPrefix": "/modul" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#18c29c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#18c29c"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://senopatiacademy.id"
    }
  }
}
